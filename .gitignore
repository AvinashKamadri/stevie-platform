__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.env
.pytest_cache/
dist/
build/
*.log
proxies.txt

# Frozen DB snapshots: large binary dumps live outside git (back them up
# separately). The MANIFEST.md + SHA256SUMS beside them ARE tracked.
snapshots/**/*.dump
snapshots/**/dump.err

# Trained model artifacts (joblib pickles): regenerable by re-running training
# against a fixed model_version + split_version + feature_version (deterministic
# solver, fixed random_state). model_registry (migration 012) is the durable
# record; the pickle itself is a build product, not source.
artifacts/
# ...but DO track the small JSON metric/calibration mirrors (M6): they make an
# M5-vs-v2 A/B a git diff and travel outside the DB (design Q4). Binary joblibs
# stay ignored above.
!artifacts/
!artifacts/metrics/
!artifacts/metrics/*.json
!artifacts/calibration/
!artifacts/calibration/*.json
artifacts/models/

# Bulk DB exports (regenerable, large; not source)
exports/
