# Copy to .env and adjust. Loaded automatically by config.py.
DATABASE_URL=postgresql://stevie:stevie@localhost:5432/stevie_platform

# Pipeline scheduling — the target site's tolerance, not an architectural choice.
# Stevie's WAF throttles parallel harvest+fetch from one IP, so: sequential.
#   sequential = harvest and fetch hold a shared lock; they cannot overlap.
#   parallel   = no lock (use for API-backed sources that tolerate concurrency).
STEVIE_PIPELINE_MODE=sequential
# Politeness ceiling for the detail-fetch rate limiter (req/s). ~1.2 is the
# measured-safe rate for Stevie; lower it if 403s appear even running solo.
STEVIE_MAX_GLOBAL_RPS=1.2
